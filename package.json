{
    "name": "label-when-in-branch",
    "description": "A Github action to label issues and PRs that are committed to a certain branch.",
    "version": "1.0",
    "homepage": "https://github.com/abompard/label-when-in-branch",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/abompard/label-when-in-branch.git"
    },
    "bugs": {
        "url": "https://github.com/abompard/label-when-in-branch/issues"
    },
    "keywords": [
        "actions",
        "node",
        "setup"
    ],
    "license": "LGPL-3.0-or-later",
    "main": "dist/index.js",
    "engines": {
        "node": ">=16"
    },
    "jest": {
        "preset": "ts-jest",
        "verbose": true,
        "clearMocks": true,
        "testEnvironment": "node",
        "moduleFileExtensions": [
            "js",
            "ts"
        ],
        "testMatch": [
            "**/*.test.ts"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/dist/"
        ],
        "transform": {
            "^.+\\.ts$": "ts-jest"
        },
        "coverageReporters": [
            "json-summary",
            "text",
            "lcov"
        ],
        "collectCoverage": true,
        "collectCoverageFrom": [
            "./src/**"
        ]
    },
    "scripts": {
        "bundle": "npm run format:write && npm run package",
        "ci-test": "jest",
        "format:write": "prettier --write '**/*.ts'",
        "format:check": "prettier --check '**/*.ts'",
        "lint": "npx eslint . -c ./.github/linters/eslintrc.mjs",
        "package": "ncc build src/index.ts --license licenses.txt",
        "package:watch": "npm run package -- --watch",
        "test": "(jest && make-coverage-badge --output-path ./badges/coverage.svg) || make-coverage-badge --output-path ./badges/coverage.svg",
        "all": "npm run format:write && npm run lint && npm run test && npm run package",
        "on-commit": "npm run format:write && npm run lint && npm run package && git add dist/index.js"
    },
    "dependencies": {
        "@actions/core": "^1.10.1 || ^3.0.0",
        "@actions/github": "^6.0.0",
        "@octokit/webhooks-types": "^7.6.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4 || ^10.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vercel/ncc": "^0.38.1",
        "eslint": "^9.0.0 || ^10.0.0",
        "eslint-plugin-github": "^6.0.0",
        "eslint-plugin-jest": "^29.0.0",
        "eslint-plugin-jsonc": "^3.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^30.0.0",
        "js-yaml": "^4.1.0",
        "make-coverage-badge": "^1.2.0",
        "prettier": "^3.0.2",
        "prettier-eslint": "^16.3.0",
        "ts-jest": "^29.1.1",
        "typescript": "^6.0.0"
    }
}
